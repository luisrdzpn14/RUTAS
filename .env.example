# Copia este archivo como ".env" y pon tus valores reales.
# El archivo .env está en .gitignore y NUNCA debe subirse a GitHub.

# API key de Google Maps Platform (con Routes API habilitada)
GOOGLE_MAPS_API_KEY=TU_API_KEY_AQUI

# Contraseña para entrar a la app (opcional: si la quitas, no pide login)
APP_PASSWORD=TU_CONTRASENA_AQUI
